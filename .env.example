# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Database
POSTGRES_DB=finans_db
POSTGRES_USER=finans_user
POSTGRES_PASSWORD=change-me

# Keycloak (admin console + master realm bootstrap)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak backend admin client secret.
# The keycloak-bootstrap container creates the `finans-backend-admin` client
# with this secret on first start. Spring Boot uses it to call the Admin REST API
# (user management, LDAP federation patching, password resets).
KC_BACKEND_CLIENT_SECRET=change-me

# Brevo SMTP relay (https://app.brevo.com → SMTP & API → SMTP).
# Used for transactional email (price alerts, user notifications).
# Free tier: 300 mails/day.
# SMTP Login is the auto-assigned address, e.g. ab8808001@smtp-brevo.com.
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
# Verified sender address — must be added in Brevo's "Senders" page first.
MAIL_FROM_ADDRESS=

# TCMB EVDS3 API key — preferred over session cookies (it never expires).
# Sign in to evds3.tcmb.gov.tr, open Profilim → API Anahtarı, copy the value.
EVDS_API_KEY=

# Session cookies — only used as fallback when EVDS_API_KEY is empty.
# Copy from DevTools → Application → Cookies after logging in. They expire
# periodically; the API key path is strongly preferred.
TCMB_EVDS3_JSESSIONID=
TCMB_EVDS3_TS_COOKIE=

# Application Ports
BACKEND_PORT=8080
FRONTEND_PORT=80
KEYCLOAK_PORT=8090
POSTGRES_PORT=5432
