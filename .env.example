# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Database
POSTGRES_DB=finans_db
POSTGRES_USER=finans_user
POSTGRES_PASSWORD=change-me

# Keycloak (admin console + master realm bootstrap)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak backend admin client secret.
# The keycloak-bootstrap container creates the `finans-backend-admin` client
# with this secret on first start. Spring Boot uses it to call the Admin REST API
# (user management, LDAP federation patching, password resets).
KC_BACKEND_CLIENT_SECRET=change-me

# Gmail SMTP for transactional email (price alerts, user notifications).
# Gmail does NOT accept your normal account password over SMTP — you have to
# generate an App Password:
#   1. Turn on 2-Step Verification at https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords, pick "Mail",
#      and copy the 16-character password (paste it with or without the
#      spaces — both work; backend strips whitespace).
# The From-address is set to GMAIL_SMTP_USERNAME automatically.
GMAIL_SMTP_USERNAME=
GMAIL_SMTP_APP_PASSWORD=

# TCMB EVDS3 API key — preferred over session cookies (it never expires).
# Sign in to evds3.tcmb.gov.tr, open Profilim → API Anahtarı, copy the value.
EVDS_API_KEY=

# Session cookies — only used as fallback when EVDS_API_KEY is empty.
# Copy from DevTools → Application → Cookies after logging in. They expire
# periodically; the API key path is strongly preferred.
TCMB_EVDS3_JSESSIONID=
TCMB_EVDS3_TS_COOKIE=

# FRED (Federal Reserve Economic Data) API key for US CPI on the inflation page.
# Free key — sign up at https://fred.stlouisfed.org/docs/api/api_key.html.
# Leave empty to disable the US series; the /api/v1/inflation page falls back
# to whatever was persisted last (empty list on a fresh install).
APP_FRED_API_KEY=

# Application Ports
BACKEND_PORT=8080
FRONTEND_PORT=80
KEYCLOAK_PORT=8090
POSTGRES_PORT=5432
