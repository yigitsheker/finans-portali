<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test logback config — overrides the production logback.xml so the Kafka
  appender (which tries to connect on every log line) doesn't spam the
  test output. Console only, INFO root level.
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
    <!-- Quiet down the noisier frameworks at WARN. -->
    <logger name="com.finansportali" level="INFO"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.apache.kafka" level="OFF"/>
</configuration>
