# GKE secret values for apply-secrets.ps1
# ---------------------------------------------------------------------------
# Copy this file to ".secrets.local.env" (gitignored) and fill REAL values.
# apply-secrets.ps1 reads it and creates the 3 Kubernetes secrets in one shot,
# so you never hand-edit secret YAMLs again when bringing the cluster back up.
#
#   cp .secrets.local.env.example .secrets.local.env   (or copy in Explorer)
#   notepad .secrets.local.env                          # fill the values
#   .\apply-secrets.ps1                                 # apply to the cluster
#
# Format: KEY=value   (no quotes, no spaces around =, # starts a comment)
# ---------------------------------------------------------------------------

# --- Postgres ---
POSTGRES_DB=finans_db
POSTGRES_USER=finans_user
POSTGRES_PASSWORD=change-me-strong-password

# --- Keycloak ---
# KC_DB_USERNAME / KC_DB_PASSWORD MUST equal the Postgres USER / PASSWORD above.
KC_DB_USERNAME=finans_user
KC_DB_PASSWORD=change-me-strong-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KC_BACKEND_CLIENT_SECRET=change-me-random-secret

# --- Backend (external APIs + mail) ---
# Leave blank if unused; the app still starts. TEFAS token has a working default.
APP_EVDS_API_KEY=
APP_FRED_API_KEY=
APP_TEFAS_BEARER_TOKEN=ST-tefaswebwse3irfmSBj4iRAzGPbAlS94Se
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
